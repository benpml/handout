{
  "name": "handout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:web": "pnpm --filter @handout/web dev",
    "dev:api": "pnpm --filter @handout/api dev",
    "dev:public-worker": "pnpm --filter @handout/public-worker dev",
    "build": "pnpm -r build",
    "check:public-boundary": "pnpm --filter @handout/web check:public-boundary",
    "check:public-bundle": "pnpm --filter @handout/web check:public-bundle",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose up -d postgres",
    "db:setup": "pnpm db:up && pnpm db:wait && pnpm db:migrate",
    "db:setup:local": "pnpm --filter @handout/db db:local setup && pnpm db:wait && pnpm db:migrate",
    "db:local:start": "pnpm --filter @handout/db db:local start",
    "db:local:stop": "pnpm --filter @handout/db db:local stop",
    "db:local:status": "pnpm --filter @handout/db db:local status",
    "db:local:createdb": "pnpm --filter @handout/db db:local createdb",
    "db:wait": "pnpm --filter @handout/db db:wait",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "pnpm --filter @handout/db db:generate",
    "db:migrate": "pnpm --filter @handout/db db:migrate",
    "db:studio": "pnpm --filter @handout/db db:studio",
    "deploy:public-worker": "pnpm --filter @handout/public-worker run deploy",
    "smoke:tracking": "pnpm --filter @handout/api smoke:tracking"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "typescript": "~6.0.2",
    "wrangler": "^4.107.0"
  }
}
